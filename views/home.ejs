<section class="hero">
  <div class="container">
    <span class="hero-badge">⚡ India's Fastest Growing Cheap SMM Panel</span>
    <h1>Buy Cheap Instagram Followers, Likes & Views — <span><%= settings.site_name %></span></h1>
    <p>Buy Instagram Followers, Likes, Views, Reels Views and Comments — plus cheap Facebook, YouTube, Telegram, TikTok and X (Twitter) marketing services. Instant delivery, real growth, starting at just <%= settings.currency %>0.20 per 1000. Add funds to your wallet and start ordering in seconds.</p>
    <div class="hero-actions">
      <% if (!currentUser) { %>
        <a href="/signup" class="btn btn-primary">Create Free Account</a>
        <a href="/services" class="btn btn-ghost">Browse Services</a>
      <% } else { %>
        <a href="/services" class="btn btn-primary">Browse Services</a>
        <a href="/deposit" class="btn btn-ghost">Add Funds</a>
      <% } %>
    </div>
    <div class="hero-stats">
      <div class="hero-stat"><strong><%= stats.services %>+</strong><span>Active Services</span></div>
      <div class="hero-stat"><strong><%= stats.orders %>+</strong><span>Orders Delivered</span></div>
      <div class="hero-stat"><strong><%= stats.users %>+</strong><span>Happy Customers</span></div>
      <div class="hero-stat"><strong>24/7</strong><span>Support</span></div>
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="section-head">
      <h2>Browse by Platform</h2>
      <p>Pick a category to see all available services and rates.</p>
    </div>
    <div class="grid grid-4">
      <% categories.slice(0,8).forEach(c => { %>
        <a href="/services?category=<%= c.id %>" class="card cat-card">
          <span class="icon"><%= c.icon %></span>
          <h3><%= c.name %></h3>
        </a>
      <% }) %>
    </div>
  </div>
</section>

<section class="section" style="background: var(--bg-soft); border-top:1px solid var(--border); border-bottom:1px solid var(--border);">
  <div class="container">
    <div class="section-head">
      <h2>🔥 Most Popular Services</h2>
      <p>Our best-selling, highest quality services.</p>
    </div>
    <div class="grid grid-3">
      <% featured.forEach(s => { %>
        <div class="card svc-card">
          <span class="svc-id"><%= s.service_code %></span>
          <h3><%= s.name %></h3>
          <p><%= s.description %></p>
          <div class="svc-meta">
            <span>Min: <%= s.min_order %></span>
            <span>Max: <%= s.max_order.toLocaleString() %></span>
          </div>
          <div style="display:flex; justify-content:space-between; align-items:center; margin-top:6px;">
            <span class="svc-rate"><%= settings.currency %><%= s.rate_per_1000 %> <small style="font-size:12px;color:var(--text-dim);font-weight:400;">/1000</small></span>
            <a href="<%= currentUser ? ('/order/' + s.id) : '/login' %>" class="btn btn-primary btn-sm">Order Now</a>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="section-head">
      <h2>How It Works</h2>
      <p>Get started in three simple steps.</p>
    </div>
    <div class="grid grid-3">
      <div class="card" style="text-align:center;">
        <span class="icon" style="font-size:32px;">1️⃣</span>
        <h3>Create an Account</h3>
        <p style="color:var(--text-dim); font-size:14px;">Sign up in seconds with your email and password.</p>
      </div>
      <div class="card" style="text-align:center;">
        <span class="icon" style="font-size:32px;">2️⃣</span>
        <h3>Add Funds to Wallet</h3>
        <p style="color:var(--text-dim); font-size:14px;">Top up your balance instantly via UPI — scan and pay, your wallet updates automatically.</p>
      </div>
      <div class="card" style="text-align:center;">
        <span class="icon" style="font-size:32px;">3️⃣</span>
        <h3>Place Your Order</h3>
        <p style="color:var(--text-dim); font-size:14px;">Choose a service, paste your link, and watch your growth begin.</p>
      </div>
    </div>
  </div>
</section>

