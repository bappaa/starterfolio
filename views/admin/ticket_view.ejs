<h1>#<%= ticket.id %> · <%= ticket.subject %></h1>
<p style="color:var(--text-dim);">From: <%= ticket.user_name %> (<%= ticket.user_email %>)</p>

<div class="chat-box">
  <% messages.forEach(m => { %>
    <div class="msg <%= m.sender %>">
      <%= m.message %>
      <div class="msg-meta"><%= m.sender === 'user' ? ticket.user_name : 'Admin (You)' %> · <%= m.created_at %></div>
    </div>
  <% }) %>
</div>

<form method="POST" action="/admin/tickets/<%= ticket.id %>/reply" class="card">
  <div class="field">
    <label>Reply</label>
    <textarea name="message" rows="3" required></textarea>
  </div>
  <div class="field">
    <label>Set Status</label>
    <select name="status" class="status-select">
      <option value="Answered" <%= ticket.status==='Answered' ? 'selected' : '' %>>Answered</option>
      <option value="Open" <%= ticket.status==='Open' ? 'selected' : '' %>>Open</option>
      <option value="Closed" <%= ticket.status==='Closed' ? 'selected' : '' %>>Closed</option>
    </select>
  </div>
  <button type="submit" class="btn btn-primary">Send Reply</button>
</form>
