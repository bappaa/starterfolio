<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= title %> · Admin · <%= settings.site_name %></title>
<link rel="stylesheet" href="/css/style.css">
</head>
<body>
<%- include('../partials/navbar') %>
<div class="admin-layout">
  <aside class="admin-sidebar">
    <a href="/admin" class="<%= path==='/admin' ? 'active' : '' %>">📊 <span class="label">Dashboard</span></a>
    <a href="/admin/users" class="<%= path==='/admin/users' ? 'active' : '' %>">👥 <span class="label">Users</span></a>
    <a href="/admin/orders" class="<%= path==='/admin/orders' ? 'active' : '' %>">📦 <span class="label">Orders</span></a>
    <a href="/admin/deposits" class="<%= path==='/admin/deposits' ? 'active' : '' %>">💰 <span class="label">Deposit Review</span><% if (typeof pendingDepositCount !== 'undefined' && pendingDepositCount > 0) { %> <span class="badge badge-warn" style="margin-left:4px;"><%= pendingDepositCount %></span><% } %></a>
    <a href="/admin/services" class="<%= path==='/admin/services' ? 'active' : '' %>">🛠 <span class="label">Services</span></a>
    <a href="/admin/categories" class="<%= path==='/admin/categories' ? 'active' : '' %>">🗂 <span class="label">Categories</span></a>
    <a href="/admin/transactions" class="<%= path==='/admin/transactions' ? 'active' : '' %>">💳 <span class="label">Transactions</span></a>
    <a href="/admin/tickets" class="<%= path==='/admin/tickets' ? 'active' : '' %>">🎫 <span class="label">Tickets</span></a>
    <a href="/admin/settings" class="<%= path==='/admin/settings' ? 'active' : '' %>">⚙️ <span class="label">Settings</span></a>
    <a href="/" >🏠 <span class="label">Back to Site</span></a>
  </aside>
  <div class="admin-content">
    <%- body %>
  </div>
</div>
<script src="/js/app.js"></script>
</body>
</html>
