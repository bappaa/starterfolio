<section class="section">
  <div class="container">
    <h3 style="font-size:26px; margin-top:0;">My Profile</h3>
    <% if (message) { %><div class="alert alert-success"><%= message %></div><% } %>
    <% if (error) { %><div class="alert alert-error"><%= error %></div><% } %>

    <div class="grid grid-2" style="align-items:flex-start;">
      <div class="card">
        <h3 style="margin-top:0;">Account Details</h3>
        <form method="POST" action="/profile">
          <div class="field">
            <label>Full Name</label>
            <input type="text" name="name" value="<%= currentUser.name %>" required>
          </div>
          <div class="field">
            <label>Email Address</label>
            <input type="email" value="<%= currentUser.email %>" disabled>
          </div>
          <div class="field">
            <label>Wallet Balance</label>
            <input type="text" value="<%= settings.currency %><%= fmtMoney(currentUser.balance) %>" disabled>
          </div>
          <button type="submit" class="btn btn-primary">Save Changes</button>
        </form>
      </div>

      <div class="card">
        <h3 style="margin-top:0;">Change Password</h3>
        <form method="POST" action="/profile/password">
          <div class="field">
            <label>Current Password</label>
            <input type="password" name="current_password" required>
          </div>
          <div class="field">
            <label>New Password</label>
            <input type="password" name="new_password" required>
          </div>
          <button type="submit" class="btn btn-primary">Update Password</button>
        </form>
      </div>
    </div>

    <div class="card" style="margin-top:20px;">
      <h3 style="margin-top:0;">API Access</h3>
      <p style="color:var(--text-dim); font-size:14px;">Use your API key to place orders programmatically.</p>
      <div class="field">
        <label>Your API Key</label>
        <input type="text" value="<%= currentUser.api_key %>" readonly onclick="this.select()">
      </div>
      <form method="POST" action="/profile/regenerate-key">
        <button type="submit" class="btn btn-outline btn-sm">🔄 Regenerate Key</button>
      </form>
    </div>
  </div>
</section>
